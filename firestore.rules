rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() &&
             request.auth.uid == userId;
    }

    // Información del usuario
    match /users/{userId} {

      allow create: if isOwner(userId);

      allow read, update, delete: if isOwner(userId);

      // Contactos
      match /contacts/{contactId} {
        allow read, delete: if isOwner(userId);

        allow create: if isOwner(userId)
                        && request.resource.data.keys().hasAll(['name', 'phone', 'relationship'])
                        && request.resource.data.name is string
                        && request.resource.data.name.size() > 0
                        && request.resource.data.name.size() <= 100
                        && request.resource.data.phone is string
                        && request.resource.data.phone.size() > 0
                        && request.resource.data.phone.size() <= 20
                        && request.resource.data.relationship is string
                        && request.resource.data.relationship.size() <= 50;

        allow update: if isOwner(userId)
                        && request.resource.data.name is string
                        && request.resource.data.name.size() > 0
                        && request.resource.data.name.size() <= 100
                        && request.resource.data.phone is string
                        && request.resource.data.phone.size() > 0
                        && request.resource.data.phone.size() <= 20;
      }

      // Recorridos
      match /trips/{tripId} {
        allow read, write: if isOwner(userId);
      }

      // Configuración
      match /settings/{settingId} {
        allow read, write: if isOwner(userId);
      }

      // Notificaciones
      match /notifications/{notificationId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Reportes públicos o compartidos
    match /reports/{reportId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if false;
    }

    // Rutas públicas compartidas (Persona 3 - GPS/rutas)
    match /public_routes/{routeId} {
      allow read: if signedIn();
      allow create: if signedIn()
                      && request.resource.data.uid == request.auth.uid;
      allow update, delete: if signedIn()
                              && resource.data.uid == request.auth.uid;
    }

    // Alertas SOS (podrán ajustarlas cuando implementen esa funcionalidad)
    match /emergency_alerts/{alertId} {
      allow create: if signedIn();
      allow read: if signedIn();
      allow update, delete: if false;
    }
  }
}
